{
  "name": "express-api-dummy",
  "version": "1.0.0",
  "description": "Dummy project for CI/CD testing",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest",
    "lint": "eslint src/**",
    "prepare": "node -e \"const {spawnSync}=require(\\\"child_process\\\");const r=spawnSync(process.platform===\\\"win32\\\"?\\\"npx.cmd\\\":\\\"npx\\\",[\\\"--no-install\\\",\\\"husky\\\"],{stdio:\\\"inherit\\\"});process.exit((r.status===0||r.status===null)?0:0)\"",
    "test:smoke": "npx jest --coverage --coverageReporters=lcov text",
    "test:newman": "node tests/run-newman-cloud.mjs",
    "test:all": "npm run test:smoke && npm run test:newman"
  },
  "dependencies": {
    "cs-pack": "^1.1.46",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "sonarqube-scanner": "^4.3.6",
    "supertest": "^6.3.4"
  }
}
